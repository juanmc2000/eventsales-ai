# EventSales AI — Environment Variables
# Copy this file to .env and fill in your local values.
# Never commit .env to version control.

# ─── Application ─────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=true

# ─── Database (PostgreSQL) ────────────────────────────────────
POSTGRES_DB=eventsales
POSTGRES_USER=eventsales
POSTGRES_PASSWORD=eventsales
DATABASE_URL=postgresql://eventsales:eventsales@postgres:5432/eventsales

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── Gmail SMTP (Test Sending) ────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-test-gmail@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=your-test-gmail@gmail.com
SMTP_FROM_NAME=EventSales AI

# ─── Gmail IMAP (Inbound Inbox Reading) ──────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=your-test-gmail@gmail.com
IMAP_PASSWORD=your-gmail-app-password

# ─── AI / LLM ────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ─── Frontend ────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
